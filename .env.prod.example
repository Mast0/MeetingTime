# Production Environment Variables
# Copy this file to .env before running docker-compose up

# The DuckDNS domain you registered (e.g. meetingtime.duckdns.org)
DOMAIN=meetingtime.duckdns.org

# The Static External IP address of your Google Cloud VM
GCP_STATIC_IP=34.123.45.67

# Generate a strong base64 key for chat encryption
ENCRYPTION_KEY=your-secure-base64-encryption-key-here
