{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "JwtSettings": {
    "Issuer": "AuthService",
    "Audience": "ApiClients",
    "ExpirationTime": "3",
    "SecretKey": "d5f4532bd535251993b0138ad089bf5102c8b145e5581a1130183db237008873"
  },
  "ReverseProxy": {
    "Routes": {
      "janus-rest": {
        "ClisterId": "janus",
        "Match": {
          "Path": "/janus/{**catch-all}"
        }
      },
      "janus-ws": {
        "ClisterId": "janus-ws",
        "Match": {
          "Path": "/janus-ws/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "janus": {
        "Destinations": {
          "janus1": {
            "Address": "http://janus:8088/"
          }
        },
        "HttpClient": {
          "DangerousAcceptAnyServerCertificateValidator": true
        }
      },
      "janus-ws": {
        "Destinations": {
          "janusws1": {
            "Address": "http://janus:8188/"
          }
        },
        "HttpRequest": {
          "AllowedMethods": [ "GET", "POST" ]
        },
        "WebSocket": {
          "Enabled":  true
        }
      }
    }
  }
}
