{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "chat_ws_route": {
        "ClusterId": "chat_ws_cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/ws/chat"
        }
      },
      "media_ws_route": {
        "ClusterId": "media_ws_cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/ws/mediaservice/{**catch-all}"
        }
      },
      "auth_route": {
        "ClusterId": "auth_cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "room_route": {
        "ClusterId": "room_cluster",
        "Match": {
          "Path": "/api/room/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "chat_ws_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "ws://chatservice:8081"
          }
        }
      },
      "media_ws_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "ws://mediaservice:3001"
          }
        }
      },
      "auth_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://authservice:8080"
          }
        }
      },
      "room_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://roomservice:8080"
          }
        }
      }
    }
  },
  "JwtSettings": {
    "Issuer": "AuthService",
    "Audience": "ApiClients",
    "ExpirationTime": "3",
    "SecretKey": "d5f4532bd535251993b0138ad089bf5102c8b145e5581a1130183db237008873"
  },
  "Seq": {
    "Url": "http://seq:5341",
    "MinimumLevel": "Information"
  }
}
